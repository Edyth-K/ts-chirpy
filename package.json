{
  "name": "ts-chirpy",
  "version": "1.0.0",
  "description": "A RESTful social network API built with TypeScript and Express.js. Users can post short messages (\"chirps\"), follow each other, and authenticate securely — all backed by a PostgreSQL database.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/index.js",
    "dev": "npx tsc && node dist/index.js",
    "test": "vitest --run",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Edyth-K/ts-chirpy.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Edyth-K/ts-chirpy/issues"
  },
  "homepage": "https://github.com/Edyth-K/ts-chirpy#readme",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.9"
  }
}
